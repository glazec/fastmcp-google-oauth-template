# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# NEVER change this in production — it invalidates all existing client tokens.
FASTMCP_JWT_SIGNING_KEY=your-long-random-string-here

# Google OAuth credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Public URL of your deployed server (no trailing slash)
# Railway: https://your-service.up.railway.app
# Local:   http://localhost:8000
BASE_URL=https://your-service.up.railway.app

# OAuth storage path — Railway: /data/oauth, Local: leave unset (defaults to ./oauth_data)
# OAUTH_STORAGE_PATH=/data/oauth
